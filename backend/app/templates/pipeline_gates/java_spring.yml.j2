name: Track1 Security Gate (Java/Spring)

on: [push, pull_request]

jobs:
  security-gate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "21"

      - name: Dependency vulnerability scan (OWASP Dependency-Check)
        uses: dependency-check/Dependency-Check_Action@main
        with:
          project: "app"
          format: "SARIF"
          args: >
            --failOnCVSS [[ '9' if block_on_severity == 'critical' else ('7' if block_on_severity == 'high' else '4') ]]

      - name: SAST (Semgrep)
        run: |
          pip install semgrep
          semgrep --config=p/java --error

      - name: Secret scan (gitleaks)
        uses: gitleaks/gitleaks-action@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
