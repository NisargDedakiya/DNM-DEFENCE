# Security
ALLOWED_ORIGINS=http://localhost:5173
API_VERSION=v1
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
LOGIN_LOCKOUT_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
FORCE_HTTPS=false
MFA_REQUIRED_FOR_STAFF=false
CLOUD_CREDENTIAL_ROTATION_DAYS=90

SENTRY_DSN=
ENABLE_METRICS=true
